# Keep the Composer distribution lean: exclude everything that a consumer
# installing the package via `composer require` does not need at runtime.
/.ai                    export-ignore
/.github                export-ignore
/docs                   export-ignore
/tests                  export-ignore
/workbench              export-ignore
/.gitattributes         export-ignore
/.gitignore             export-ignore
/boost.json             export-ignore
/phpstan.neon.dist      export-ignore
/phpunit.xml.dist       export-ignore
/pint.json              export-ignore
/testbench.yaml         export-ignore
/release-please-config.json          export-ignore
/.release-please-manifest.json       export-ignore
